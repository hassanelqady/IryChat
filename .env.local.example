# ── Supabase ──────────────────────────────
# احصل عليهم من: https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# ── Meta / Instagram ───────────────────────
# هتحتاجهم لاحقاً لما تربط انستجرام
META_APP_ID=
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=xchat_webhook_secret_2025

# ── App ────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000